# ======================================================
# ClubConnect Backend — Environment Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to git!
# ======================================================

# MongoDB connection string
# Local:  mongodb://localhost:27017/clubconnect
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/clubconnect
MONGO_URI=

# JWT secret — use a long random string, e.g.:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Server port
PORT=5000
